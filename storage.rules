rules_version = '2';

// Reglas de Firebase Storage para las imágenes de ejercicios (figuras de geometría, etc.)
//
// CÓMO APLICARLAS:
//   Firebase Console -> Storage -> Reglas -> pegar este archivo -> Publicar
//
// Misma lista de admins que firestore.rules / admin.html (ALLOWED_EMAILS). Si agregás
// un nuevo docente/admin, actualizá los tres lugares.

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email in [
               'joaquin.alva@activelearning.com.ar',
               'colaboradores.aprendizajes@activelearning.com.ar'
             ];
    }

    // Cualquier estudiante autenticado necesita poder VER la figura del ejercicio
    // durante el examen; solo el admin puede subir o borrar imágenes.
    match /exercise-images/{category}/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin() &&
                      request.resource.size < 5 * 1024 * 1024 &&
                      request.resource.contentType.matches('image/(jpeg|png)');
    }
  }
}
